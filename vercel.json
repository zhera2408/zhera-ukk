{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.3"
        },
        "*.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "src": "/(assets/.*)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}